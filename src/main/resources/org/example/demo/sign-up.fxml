<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="405.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.demo.SignUpController">
   <children>
      <Label layoutX="46.0" layoutY="54.0" text="Username">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Label layoutX="49.0" layoutY="125.0" text="Password">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <TextField fx:id="tf_username" layoutX="177.0" layoutY="59.0" prefHeight="35.0" prefWidth="149.0" />
      <PasswordField fx:id="tf_password" layoutX="177.0" layoutY="130.0" prefHeight="35.0" prefWidth="149.0" />
      <Button fx:id="button_sign_up" layoutX="118.0" layoutY="200.0" mnemonicParsing="false" prefHeight="35.0" prefWidth="170.0" style="-fx-background-color: #fce703; -fx-border-color: grey; -fx-cursor: hand;" text="Sign up">
         <font>
            <Font size="19.0" />
         </font>
      </Button>
      <Text layoutX="125.0" layoutY="278.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Already a member?" />
      <Button fx:id="button_log_in" layoutX="228.0" layoutY="261.0" mnemonicParsing="false" style="-fx-cursor: hand; -fx-background-color: transparent;" text="Log in!" textFill="#164de4" underline="true">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
